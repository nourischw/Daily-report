---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-TW" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="每日 IT 資訊報告 - 繁體中文" />
    <meta name="author" content="Nouris" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-[#0d1117] text-gray-100 min-h-screen font-sans">
    <!-- Reading Progress Bar -->
    <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-pink-500 z-[100] transition-all duration-150" style="width: 0%"></div>
    
    <!-- Back to Top Button -->
    <button id="back-to-top" class="fixed bottom-6 right-6 w-14 h-14 rounded-full bg-gradient-to-br from-accent-600 to-purple-600 hover:from-accent-500 hover:to-purple-500 text-white shadow-2xl opacity-0 pointer-events-none transition-all duration-300 flex items-center justify-center text-xl z-50 hover:scale-110" title="回到頂部">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>

    <slot />

    <!-- Footer -->
    <footer class="border-t border-dark-600 bg-dark-900/50 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="text-center md:text-left">
            <p class="text-gray-400">作者：<span class="text-white font-medium">Nouris</span></p>
            <p class="text-gray-500 text-sm mt-1">由 <a href="https://astro.build" target="_blank" class="text-accent-500 hover:underline">Astro</a> 驅動 · 數據每日更新</p>
          </div>
          <div class="flex items-center gap-4">
            <a href="https://github.com/nourischw/Daily-report" target="_blank" class="text-gray-400 hover:text-white transition-colors" title="GitHub">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * { 
    scrollbar-width: thin; 
    scrollbar-color: #30363d #0d1117; 
  }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: #0d1117; }
  ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #484f58; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', 'Noto Sans TC', system-ui, -apple-system, sans-serif; background: #0d1117; line-height: 1.7; }
  
  /* Selection */
  ::selection { background: rgba(88, 166, 255, 0.3); color: #f0f6fc; }
  
  /* Markdown Content Styling */
  .markdown-content { font-size: 1rem; line-height: 1.8; }
  .markdown-content h1 { display: none; }
  .markdown-content h2 { 
    font-size: 1.5rem; 
    font-weight: 700; 
    color: #f0f6fc; 
    margin: 2rem 0 1rem; 
    padding-bottom: 0.75rem; 
    border-bottom: 2px solid #21262d; 
  }
  .markdown-content h2:first-of-type { display: none; }
  .markdown-content h3 { 
    font-size: 1.15rem; 
    font-weight: 600; 
    color: #c9d1d9; 
    margin: 1.75rem 0 0.75rem; 
    padding: 0.75rem;
    background: linear-gradient(135deg, rgba(88, 166, 255, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);
    border-radius: 8px;
    border-left: 3px solid #58a6ff;
  }
  .markdown-content p { color: #9ca3af; line-height: 1.9; margin: 1rem 0; }
  .markdown-content a { 
    color: #58a6ff; 
    text-decoration: none; 
    border-bottom: 1px solid transparent; 
    transition: all 0.2s ease; 
    padding-bottom: 2px;
  }
  .markdown-content a:hover { 
    color: #79b8ff; 
    border-bottom-color: #58a6ff; 
  }
  .markdown-content strong { color: #f0f6fc; font-weight: 600; }
  .markdown-content ul, .markdown-content ol { padding-left: 1.5rem; margin: 1rem 0; }
  .markdown-content ul { list-style: none; padding-left: 0; }
  .markdown-content ul li { 
    color: #9ca3af; 
    line-height: 1.8; 
    margin: 0.6rem 0; 
    padding: 0.75rem 1rem;
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
    transition: all 0.2s ease;
  }
  .markdown-content ul li:hover { 
    background: rgba(88, 166, 255, 0.05);
    transform: translateX(4px);
  }
  .markdown-content ol { list-style: none; padding-left: 0; counter-reset: item; }
  .markdown-content ol li { 
    color: #9ca3af; 
    line-height: 1.8; 
    margin: 0.6rem 0; 
    padding: 0.75rem 1rem 0.75rem 2.5rem;
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
    position: relative;
    counter-increment: item;
  }
  .markdown-content ol li::before {
    content: counter(item);
    position: absolute;
    left: 0.75rem;
    top: 0.75rem;
    width: 1.5rem;
    height: 1.5rem;
    background: linear-gradient(135deg, #58a6ff 0%, #8b5cf6 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
  }
  .markdown-content code { 
    font-family: 'JetBrains Mono', monospace; 
    background: #161b22; 
    padding: 0.2rem 0.5rem; 
    border-radius: 4px; 
    font-size: 0.875em; 
    color: #f0883e; 
  }
  .markdown-content pre { 
    background: #161b22; 
    padding: 1rem; 
    border-radius: 12px; 
    overflow-x: auto; 
    margin: 1.25rem 0; 
    border: 1px solid #30363d;
  }
  .markdown-content pre code { background: none; padding: 0; color: #c9d1d9; }
  .markdown-content hr { border: none; border-top: 1px solid #21262d; margin: 2.5rem 0; }
  
  /* Tab Buttons */
  .tab-btn { 
    @apply px-5 py-3 rounded-xl bg-dark-700 hover:bg-dark-600 transition-all duration-200 flex items-center gap-2 font-medium;
    border: 1px solid transparent;
  }
  .tab-btn:hover {
    border-color: rgba(88, 166, 255, 0.3);
  }
  .tab-btn.active {
    @apply bg-dark-600;
    border-color: #58a6ff;
    box-shadow: 0 0 20px rgba(88, 166, 255, 0.2);
  }
  
  /* Card Hover Effects */
  .card-hover {
    box-shadow: 0 0 0 1px rgba(48, 54, 61, 0.5), 0 8px 24px rgba(0,0,0,0.4);
    transition: all 0.3s ease;
  }
  .card-hover:hover { 
    box-shadow: 0 0 0 1px rgba(88, 166, 255, 0.4), 0 16px 48px rgba(0,0,0,0.5);
    transform: translateY(-4px);
  }
  
  /* Input Styling */
  input[type="date"] { color-scheme: dark; }
  input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(1);
    cursor: pointer;
  }
  
  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px rgba(88, 166, 255, 0.3); }
    50% { box-shadow: 0 0 30px rgba(88, 166, 255, 0.5); }
  }
  .animate-fade-in { animation: fadeIn 0.5s ease forwards; }
  .animate-pulse-glow { animation: pulse-glow 2s ease-in-out infinite; }
</style>

<script>
  // Progress Bar
  const progressBar = document.getElementById('progress-bar');
  function updateProgress() { 
    if (!progressBar) return; 
    const scrollTop = window.scrollY; 
    const docHeight = document.documentElement.scrollHeight - window.innerHeight; 
    const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0; 
    progressBar.style.width = progress + '%'; 
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  
  // Back to Top Button
  const backToTop = document.getElementById('back-to-top');
  function toggleBackToTop() { 
    if (!backToTop) return; 
    if (window.scrollY > 400) { 
      backToTop.classList.remove('opacity-0', 'pointer-events-none', 'scale-75');
      backToTop.classList.add('opacity-100', 'scale-100'); 
    } else { 
      backToTop.classList.add('opacity-0', 'pointer-events-none', 'scale-75'); 
      backToTop.classList.remove('opacity-100', 'scale-100'); 
    } 
  }
  backToTop?.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); });
  window.addEventListener('scroll', toggleBackToTop, { passive: true });
  toggleBackToTop();
</script>
