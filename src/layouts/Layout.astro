---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-TW" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="每日 IT 資訊報告 - 繁體中文" />
    <meta name="author" content="Nouris" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-[#0d1117] text-gray-100 min-h-screen font-sans">
    <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-gradient-to-r from-blue-500 to-purple-500 z-50 transition-all duration-150" style="width: 0%"></div>
    <slot />
    <button id="back-to-top" class="fixed bottom-6 right-6 w-12 h-12 rounded-full bg-dark-700 hover:bg-dark-600 text-white shadow-lg opacity-0 pointer-events-none transition-all duration-300 flex items-center justify-center text-xl" title="回到頂部">↑</button>
  </body>
</html>

<style is:global>
  * { scrollbar-width: thin; scrollbar-color: #30363d #0d1117; }
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: #0d1117; }
  ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #484f58; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', 'Noto Sans TC', system-ui, -apple-system, sans-serif; background: #0d1117; line-height: 1.7; }
  
  .markdown-content { font-size: 1rem; line-height: 1.8; }
  .markdown-content h1 { font-size: 1.75rem; font-weight: 700; color: #f0f6fc; margin: 2rem 0 1rem; padding-bottom: 0.75rem; border-bottom: 2px solid #21262d; }
  .markdown-content h1:first-child { display: none; }
  .markdown-content h2 { font-size: 1.35rem; font-weight: 600; color: #f0f6fc; margin: 1.75rem 0 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid #21262d; }
  .markdown-content h3 { font-size: 1.15rem; font-weight: 600; color: #c9d1d9; margin: 1.5rem 0 0.5rem; }
  .markdown-content p { color: #9ca3af; line-height: 1.85; margin: 0.75rem 0; }
  .markdown-content a { color: #58a6ff; text-decoration: none; border-bottom: 1px solid transparent; transition: all 0.15s ease; padding-bottom: 1px; }
  .markdown-content a:hover { color: #79b8ff; border-bottom-color: #58a6ff; }
  .markdown-content strong { color: #f0f6fc; font-weight: 600; }
  .markdown-content ul, .markdown-content ol { padding-left: 1.5rem; margin: 1rem 0; }
  .markdown-content ul { list-style: disc; }
  .markdown-content ul li { color: #9ca3af; line-height: 1.8; margin: 0.4rem 0; }
  .markdown-content ul li::marker { color: #58a6ff; }
  .markdown-content ol li::marker { color: #58a6ff; font-weight: 600; }
  .markdown-content code { font-family: 'JetBrains Mono', monospace; background: #161b22; padding: 0.2rem 0.4rem; border-radius: 4px; font-size: 0.9em; color: #f0883e; }
  .markdown-content pre { background: #161b22; padding: 1rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
  .markdown-content pre code { background: none; padding: 0; color: #c9d1d9; }
  .markdown-content hr { border: none; border-top: 1px solid #21262d; margin: 2rem 0; }
  .tab-btn { @apply px-5 py-2.5 rounded-xl bg-dark-700 hover:bg-dark-600 transition-all duration-200 flex items-center gap-2 font-medium; }
  .tab-btn.ring-2 { box-shadow: 0 0 16px rgba(88, 166, 255, 0.3); }
  .bg-\[\#161b22\] { box-shadow: 0 0 0 1px rgba(48, 54, 61, 0.5), 0 8px 24px rgba(0,0,0,0.4); transition: all 0.2s ease; }
  .bg-\[\#161b22\]:hover { box-shadow: 0 0 0 1px rgba(88, 166, 255, 0.3), 0 12px 40px rgba(0,0,0,0.5); transform: translateY(-2px); }
  input[type="date"] { color-scheme: dark; }
  ::selection { background: rgba(88, 166, 255, 0.3); color: #f0f6fc; }
</style>

<script>
  const progressBar = document.getElementById('progress-bar');
  function updateProgress() { if (!progressBar) return; const scrollTop = window.scrollY; const docHeight = document.documentElement.scrollHeight - window.innerHeight; const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0; progressBar.style.width = progress + '%'; }
  window.addEventListener('scroll', updateProgress, { passive: true });
  
  const backToTop = document.getElementById('back-to-top');
  function toggleBackToTop() { if (!backToTop) return; if (window.scrollY > 300) { backToTop.classList.remove('opacity-0', 'pointer-events-none'); backToTop.classList.add('opacity-100'); } else { backToTop.classList.add('opacity-0', 'pointer-events-none'); backToTop.classList.remove('opacity-100'); } }
  backToTop?.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }); });
  window.addEventListener('scroll', toggleBackToTop, { passive: true });
</script>
