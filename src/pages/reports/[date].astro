---
import Layout from '../../layouts/Layout.astro';

function parseMd(md: string): string {
  if (!md) return '';
  return md
    .replace(/^### (.+)$/gm, '<h3>$1</h3>')
    .replace(/^## (.+)$/gm, '<h2>$1</h2>')
    .replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener" class="text-accent-400 hover:underline inline-flex items-center gap-1">$1 <span class="text-xs">→</span></a>')
    .replace(/^- (.+)$/gm, '<li class="mb-2">$1</li>')
    .replace(/^(\d+)\. (.+)$/gm, '<li class="mb-2">$2</li>')
    .replace(/(<li.*>.*<\/li>\n?)+/g, '<ul class="space-y-2">$&</ul>')
    .replace(/\n\n/g, '<br><br>')
    .trim();
}

export async function getStaticPaths() {
  const fs = await import('fs');
  const path = await import('path');
  
  // New structure: reports/YYYY/YYYY-MM/YYYY-MM-DD/
  const reportsDir = path.join(process.cwd(), 'reports');
  const dates: string[] = [];
  
  try {
    if (fs.existsSync(reportsDir)) {
      const years = fs.readdirSync(reportsDir);
      for (const year of years) {
        const yearPath = path.join(reportsDir, year);
        if (!fs.statSync(yearPath).isDirectory()) continue;
        
        const months = fs.readdirSync(yearPath);
        for (const month of months) {
          const monthPath = path.join(yearPath, month);
          if (!fs.statSync(monthPath).isDirectory()) continue;
          
          const dateDirs = fs.readdirSync(monthPath);
          for (const dateDir of dateDirs) {
            if (/^\d{4}-\d{2}-\d{2}$/.test(dateDir)) {
              dates.push(dateDir);
            }
          }
        }
      }
    }
  } catch (e) {
    console.log('Reports directory not ready yet');
  }
  
  // Sort dates descending (newest first)
  dates.sort().reverse();
  
  // If no dates found, return empty array (no pages will be generated)
  if (dates.length === 0) {
    return [];
  }
  
  return dates.map(date => ({
    params: { date },
    props: { date }
  }));
}

const { date } = Astro.params;

const channels = [
  { id: 'github', name: 'GitHub 熱度', icon: '💻', color: 'text-white' },
  { id: 'ai', name: 'AI 新聞', icon: '🤖', color: 'text-purple-400' },
  { id: 'it', name: 'IT 資訊', icon: '📰', color: 'text-blue-400' },
  { id: 'jobs', name: 'IT 工作介紹', icon: '💼', color: 'text-green-400' },
  { id: 'polymarket', name: 'Polymarket', icon: '🔮', color: 'text-yellow-400' },
];

const fs = await import('fs');
const path = await import('path');

// New structure: reports/YYYY/YYYY-MM/YYYY-MM-DD/
const year = (date as string).substring(0, 4);
const month = (date as string).substring(5, 7);
const reportsDir = path.join(process.cwd(), 'reports', year, month, date as string);

let reports: Record<string, string> = {
  github: '',
  ai: '',
  it: '',
  jobs: '',
  polymarket: ''
};

let reportExists = false;

try {
  if (fs.existsSync(reportsDir)) {
    reportExists = true;
    const files = fs.readdirSync(reportsDir);
    for (const file of files) {
      if (file.endsWith('.md')) {
        const channel = file.replace('.md', '').toLowerCase();
        if (reports[channel] !== undefined) {
          const content = fs.readFileSync(path.join(reportsDir, file), 'utf-8');
          reports[channel] = content;
        }
      }
    }
  }
} catch (e) {
  console.log('Report directory not ready yet');
}

// Get all available dates for archive
const allDates: string[] = [];
try {
  const rootReportsDir = path.join(process.cwd(), 'reports');
  if (fs.existsSync(rootReportsDir)) {
    const years = fs.readdirSync(rootReportsDir);
    for (const year of years) {
      const yearPath = path.join(rootReportsDir, year);
      if (!fs.statSync(yearPath).isDirectory()) continue;
      
      const months = fs.readdirSync(yearPath);
      for (const month of months) {
        const monthPath = path.join(yearPath, month);
        if (!fs.statSync(monthPath).isDirectory()) continue;
        
        const dateDirs = fs.readdirSync(monthPath);
        for (const dateDir of dateDirs) {
          if (/^\d{4}-\d{2}-\d{2}$/.test(dateDir)) {
            allDates.push(dateDir);
          }
        }
      }
    }
  }
} catch (e) {
  console.log('Error reading dates');
}
allDates.sort().reverse();

// Format date for display
const formattedDate = date ? new Date(date.replace(/-/g, '/')).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long'
}) : '';
---

<Layout title={`${date} 每日 IT 資訊報告`}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="text-center mb-8">
      <a href="/Daily-report/" class="inline-block mb-4 text-accent-500 hover:text-accent-400 transition-colors">
        ← 返回首頁
      </a>
      <h1 class="text-4xl font-bold mb-2 bg-gradient-to-r from-accent-500 to-purple-400 bg-clip-text text-transparent">
        每日 IT 資訊報告
      </h1>
      <p class="text-gray-400 text-lg">{formattedDate}</p>
    </header>

    {reportExists ? (
      <>
        <!-- Tab Navigation -->
        <nav class="flex flex-wrap justify-center gap-2 mb-8">
          {channels.map((channel) => (
            <button
              data-tab={channel.id}
              class="tab-btn px-4 py-2 rounded-lg bg-dark-700 hover:bg-dark-600 transition-all duration-200 flex items-center gap-2 font-medium"
            >
              <span>{channel.icon}</span>
              <span class={channel.color}>{channel.name}</span>
            </button>
          ))}
        </nav>

        <!-- Content Area -->
        <main class="bg-dark-800 rounded-2xl p-6 min-h-[500px] shadow-xl border border-dark-700">
          {channels.map((channel, index) => (
            <div
              id={`content-${channel.id}`}
              class={`channel-content ${index === 0 ? 'block' : 'hidden'}`}
            >
              <h2 class="text-2xl font-semibold mb-6 flex items-center gap-3">
                <span class="text-3xl">{channel.icon}</span>
                <span class={channel.color}>{channel.name}</span>
              </h2>
              <div class="prose prose-invert prose-lg max-w-none">
                {reports[channel.id] ? (
                  <article class="markdown-content" set:html={parseMd(reports[channel.id])} />
                ) : (
                  <p class="text-gray-500">暫無內容</p>
                )}
              </div>
            </div>
          ))}
        </main>
      </>
    ) : (
      <div class="bg-dark-800 rounded-2xl p-12 text-center shadow-xl border border-dark-700">
        <p class="text-6xl mb-4">📋</p>
        <h2 class="text-2xl font-semibold mb-2">報告尚未生成</h2>
        <p class="text-gray-400">選擇其他日期查看過往報告</p>
      </div>
    )}

    <!-- Archive Section -->
    <section class="mt-12 bg-dark-800 rounded-2xl p-6 shadow-xl border border-dark-700">
      <h3 class="text-xl font-semibold mb-4 text-gray-300">📁 報告歸檔</h3>
      <div class="flex flex-wrap gap-2">
        {allDates.length > 0 ? (
          allDates.map(d => (
            <a
              href={`/Daily-report/reports/${d}`}
              class={`px-3 py-2 rounded-lg transition-all ${
                d === date
                  ? 'bg-accent-600 text-white'
                  : 'bg-dark-700 hover:bg-dark-600 text-gray-300'
              }`}
            >
              {d}
            </a>
          ))
        ) : (
          <p class="text-gray-500">暫無歷史報告</p>
        )}
      </div>
    </section>

    <!-- Footer -->
    <footer class="text-center text-gray-500 text-sm mt-8">
      <p>作者：<strong>Nouris</strong> · 由 <a href="https://astro.build" target="_blank" class="text-accent-500 hover:underline">Astro</a> 驅動 · 自動更新</p>
    </footer>
  </div>

  <script>
    // Tab switching logic
    const tabBtns = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.channel-content');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        
        // Update buttons
        tabBtns.forEach(b => b.classList.remove('bg-dark-600', 'ring-2', 'ring-accent-500'));
        btn.classList.add('bg-dark-600', 'ring-2', 'ring-accent-500');
        
        // Update content
        contents.forEach(c => {
          if (c.id === `content-${tabId}`) {
            c.classList.remove('hidden');
            c.classList.add('block');
          } else {
            c.classList.add('hidden');
            c.classList.remove('block');
          }
        });
      });
    });

    // Set first tab as active
    tabBtns[0]?.classList.add('bg-dark-600', 'ring-2', 'ring-accent-500');
  </script>
</Layout>
